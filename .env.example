# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Anthropic API (for Voice Commands)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PWA Demo Mode (uncomment to disable service worker for demos)
# VITE_DEMO_MODE=true

# ─── Founder Console (/founder) ─────────────────────────────────────────────
# Comma-separated list of email addresses that can access /founder routes.
# This is a UI-layer guard only. Real security is enforced by the founder-api
# edge function which checks FOUNDER_EMAILS (set via Supabase secrets, NOT VITE_).
VITE_FOUNDER_EMAILS=your@email.com
